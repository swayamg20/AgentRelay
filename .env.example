# Copy this file to `.env`. docker-compose auto-reads `.env` for both
# the postgres and the relay containers when you run with --profile selfhost.
#
# Local-dev defaults are committed here; they're safe to use on your own
# machine. Before exposing the relay publicly, regenerate every secret:
#
#     openssl rand -hex 32       # for PEPPER (>= 32 bytes)
#     openssl rand -hex 16       # for ENCRYPTION_KEY / ADMIN_TOKEN / METRICS_TOKEN

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=agentrelay-dev

# ─── Relay (set via docker-compose, also for `pnpm --filter relay dev`) ────

# When the relay runs INSIDE docker-compose --profile selfhost, RELAY_DATABASE_URL
# is set to talk to the postgres container over the docker network — see
# docker-compose.yml. When you run the relay on your host with `pnpm --filter
# relay dev`, this var is what you export instead, pointing at localhost:5433.
RELAY_DATABASE_URL=postgres://agentrelay:agentrelay-dev@localhost:5433/agentrelay

# Required secrets. Stable values (don't regenerate between relay restarts —
# API keys are hashed with PEPPER, so a new pepper invalidates every key).
RELAY_PEPPER=stable-dev-pepper-do-not-randomise-between-restarts-32+bytes
RELAY_ENCRYPTION_KEY=stable-dev-encryption-key-32-bytes-min
RELAY_ADMIN_TOKEN=stable-dev-admin-token
RELAY_METRICS_TOKEN=stable-dev-metrics-token

# Public-facing URL of the relay (no trailing slash). Used in Slack deep links
# the dispatcher emits. Set to your real domain for production.
RELAY_PUBLIC_URL=http://localhost:8080

# `production` | `staging` | `dev`. Affects log level defaults.
RELAY_ENV=dev

# `debug` | `info` | `warn` | `error`.
RELAY_LOG_LEVEL=info

# Host port the relay binds to (container always listens on 8080 internally).
RELAY_PORT=8080

# Audit log retention (days). Daily job deletes rows older than this.
RELAY_AUDIT_RETENTION_DAYS=90

# Per-agent rate limit (requests/minute) on /a2a.
RELAY_RATE_LIMIT_PER_MIN=60

# Postgres connection pool size.
RELAY_DB_POOL_SIZE=20

# Optional: OTLP traces endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── MCP server (per-developer laptop) ─────────────────────────────────────
# These are read from ~/.agentrelay/config.json at runtime, not from .env.
# The two below are testing overrides only.

# AGENTRELAY_CONFIG_PATH=/path/to/alternate/config.json
# AGENTRELAY_DEBUG=1
