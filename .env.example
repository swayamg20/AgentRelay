# Copy to .env for local development.
# Production values come from your deployment platform's secret manager.

# ─── Relay (server) ─────────────────────────────────────────────────────────

# Postgres connection. Default matches docker-compose.yml.
RELAY_DATABASE_URL=postgres://agentrelay:agentrelay-dev@localhost:5433/agentrelay

# API key hashing pepper. >= 32 random bytes. Rotate via the standard procedure.
RELAY_PEPPER=changeme-development-pepper-must-be-32-bytes-or-longer

# Symmetric key for encrypting Slack webhook URLs at rest.
RELAY_ENCRYPTION_KEY=changeme-development-encryption-key

# Bearer for /admin/* endpoints. Used during initial team setup only.
RELAY_ADMIN_TOKEN=changeme-admin-token

# Bearer for GET /metrics.
RELAY_METRICS_TOKEN=changeme-metrics-token

# Public-facing URL of the relay (no trailing slash). Used in Slack deep links.
RELAY_PUBLIC_URL=http://localhost:8080

# `production` | `staging` | `dev`. Affects log level defaults and error verbosity.
RELAY_ENV=dev

# `debug` | `info` | `warn` | `error`. Default `info` in prod, `debug` in dev.
RELAY_LOG_LEVEL=debug

# Port the Hono server binds to.
RELAY_PORT=8080

# Audit log retention (days). Daily job deletes rows older than this.
RELAY_AUDIT_RETENTION_DAYS=90

# Per-agent rate limit (requests/minute) on /a2a.
RELAY_RATE_LIMIT_PER_MIN=60

# Postgres connection pool size.
RELAY_DB_POOL_SIZE=20

# Optional: OTLP traces endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── MCP server (per-developer laptop) ──────────────────────────────────────
# These are read from ~/.agentrelay/config.json at runtime, not from .env.
# The two below are testing overrides only.

# AGENTRELAY_CONFIG_PATH=/path/to/alternate/config.json
# AGENTRELAY_DEBUG=1
